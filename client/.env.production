# Production build configuration
# VITE_API_URL_PROD: set this in Render/Vercel env vars for real deployments.
# Leave unset here so local 'npm run build && npm run preview' uses the
# relative /api fallback (proxied to localhost:8000 via vite preview proxy).
VITE_ENV=production
VITE_API_URL_DEV=http://localhost:8000/api
