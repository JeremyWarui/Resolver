# API Configuration
# Vite automatically sets MODE based on command:
# - 'npm run dev' → MODE = 'development'
# - 'npm run build' → MODE = 'production'

# Development API (local Django server)
VITE_API_URL_DEV=http://localhost:8000/api/v1

# Production API URL — set this in Render/Vercel environment variables.
# Leave unset here so local preview builds use the relative /api fallback
# (proxied to localhost:8000 via vite preview proxy for phone/LAN testing).
# VITE_API_URL_PROD=https://django-resolver.onrender.com/api/v1
